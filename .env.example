PORT=3000
WIX_AUTH_TOKEN=PUT_YOUR_WIX_TOKEN_HERE
WIX_SITE_ID=PUT_YOUR_WIX_SITE_ID_HERE
WIX_COLLECTION_ID=Import1
WIX_PAGE_LIMIT=100
WIX_DEDUPE_FIELDS=project,gender,roleName
# Dedupe cron: empty = daily 03:00; off = disabled
CRON_EXPRESSION=
# Shoot-date cleanup cron: empty = daily 03:30; off = disabled
CRON_CLEANUP_EXPRESSION=
CRON_TIMEZONE=
CRON_BATCH_SIZE=100
CRON_CLEANUP_BATCH_SIZE=100
# Field name in Wix collection for shoot date
WIX_SHOOT_DATE_FIELD=shoot_date
# N/A / empty shoot_date: delete if created older than this many months
STALE_NA_MONTHS=2
# Optional: compare "today" vs shoot in this IANA zone (e.g. Asia/Karachi)
CLEANUP_DATE_TIMEZONE=
